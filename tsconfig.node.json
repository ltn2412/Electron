{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@/*": ["src/*"]
    }
  }
}
